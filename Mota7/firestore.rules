rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ——— دوال مساعدة ———

    /**
     * أدمن: إما مطالبة مخصصة admin=true (مُفضّلة للوحة الأدمن)
     * أو إيميل ضمن القائمة (مستخدمو التطبيق {phone}@mota7.com ليسوا أدمن).
     */
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (request.auth.token.email is string &&
          request.auth.token.email in [
            'hossam@mota7.com',
            'ibrahem@mota7.com',
            'admin@mota7.com'
          ])
      );
    }

    /** معرّف مستند users/{phone} من إيميل تسجيل الدخول */
    function userDocIdFromAuth() {
      return request.auth != null && request.auth.token.email is string
        ? request.auth.token.email.replace('@mota7.com', '')
        : '';
    }

    /**
     * نشط إذا لم يوجد حقل isActive أو isActive == true.
     * معطّل عند isActive == false فقط.
     */
    function isUserActive() {
      let phone = userDocIdFromAuth();
      return request.auth != null &&
        request.auth.token.email is string &&
        exists(/databases/$(database)/documents/users/$(phone)) &&
        userDocIsActive(phone);
    }

    function userDocIsActive(phone) {
      let u = get(/databases/$(database)/documents/users/$(phone)).data;
      return u.isActive == true || !u.keys().hasAny(['isActive']);
    }

    function ownsUserProfile(userId) {
      return request.auth != null &&
        (request.auth.uid == userId ||
          (request.auth.token.email is string &&
            request.auth.token.email.matches('.*@mota7\\.com$') &&
            userId == request.auth.token.email.replace('@mota7.com', '')));
    }

    /**
     * إنشاء مستند users/{phone} (تسجيل جديد أو ترحيل من mota7-app):
     * - معرّف المستند = رقم الهاتف كما في التطبيق (01…).
     * - الحقول phone و uid و systemEmail متسقة مع Auth (نفس ما يرسله register والترحيل).
     * الأدمن يتجاوز هذه القيود عبر فرع isAdmin() في allow create.
     */
    function userProfileCreateAllowed(userId) {
      return ownsUserProfile(userId) &&
        request.resource.data.phone == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.systemEmail is string &&
        request.resource.data.systemEmail == (userId + '@mota7.com');
    }

    function ownsAdResource() {
      return request.auth != null &&
        (resource.data.userId == request.auth.uid ||
          (request.auth.token.email is string &&
            resource.data.owner_phone == request.auth.token.email.replace('@mota7.com', '')));
    }

    function ownsAdOnCreate() {
      return request.auth != null &&
        (request.resource.data.userId == request.auth.uid ||
          (request.auth.token.email is string &&
            request.resource.data.owner_phone == request.auth.token.email.replace('@mota7.com', '')));
    }

    function isStatsOnlyAdUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['stats', 'call_clicks', 'whatsapp_clicks', 'impression_count']);
    }

    /**
     * طالب الخدمة يحدّث متوسط تقييم المزود على إعلان مقدم الخدمة (submitOrderProviderRating).
     *
     * لا يُشترط request.auth لأن:
     * - تحديث الطلب نفسه مسموح بدون تسجيل (orders: allow write: if true)، والعميل قد يقيّم
     *   من «طلباتي» بدون جلسة Firebase Auth.
     * - يُسمح فقط بتغيير 3 حقول عليا (لا يمكن تعديل owner أو نص الإعلان).
     *
     * تحذير أمني: أي عميل يمكنه رفع/خفض المتوسط إن عرف معرف الإعلان؛ للإنتاج الأقوى استخدم
     * Callable Function أو اشترط تسجيل الدخول في التطبيق قبل الإرسال.
     */
    function isProviderServiceRatingAdUpdate() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return diff.hasOnly([
          'provider_service_rating_count',
          'provider_service_rating_sum',
          'last_provider_rating',
        ]) &&
        request.resource.data.last_provider_rating is map;
    }

    function isAdminAppListedEmailAuth() {
      return request.auth != null &&
        request.auth.token.email is string &&
        request.auth.token.email in [
          'hossam@mota7.com',
          'ibrahem@mota7.com',
          'admin@mota7.com'
        ];
    }

    function mota7ServiceUserOwnsOwnerPhone(ownerPhone) {
      return request.auth != null &&
        ownerPhone is string &&
        exists(/databases/$(database)/documents/users/$(ownerPhone)) &&
        get(/databases/$(database)/documents/users/$(ownerPhone)).data.uid == request.auth.uid;
    }

    function adminAppDeviceTokenWritable() {
      let d = request.resource.data;
      return d.token is string
        && d.admin_email == request.auth.token.email
        && isAdminAppListedEmailAuth()
        && d.app == 'mota7_admin';
    }

    function mota7AppDeviceTokenWritable() {
      let d = request.resource.data;
      return d.token is string
        && d.owner_phone is string
        && d.app == 'mota7'
        && mota7ServiceUserOwnsOwnerPhone(d.owner_phone);
    }

    match /device_tokens/{tokenDocId} {
      allow read: if false;
      allow create: if isAdmin() || adminAppDeviceTokenWritable() || mota7AppDeviceTokenWritable();
      allow update: if isAdmin()
        || (
          resource.data.app == 'mota7_admin'
          && request.resource.data.app == 'mota7_admin'
          && adminAppDeviceTokenWritable()
          && request.resource.data.admin_email == resource.data.admin_email
        )
        || (
          resource.data.app == 'mota7'
          && request.resource.data.app == 'mota7'
          && request.resource.data.owner_phone == resource.data.owner_phone
          && mota7AppDeviceTokenWritable()
        );
      allow delete: if isAdmin()
        || (
          resource.data.app == 'mota7_admin'
          && resource.data.admin_email == request.auth.token.email
          && isAdminAppListedEmailAuth()
        )
        || (
          resource.data.app == 'mota7'
          && resource.data.owner_phone is string
          && mota7ServiceUserOwnsOwnerPhone(resource.data.owner_phone)
        );
    }

    /**
     * فحص الحظر عند إرسال طلب بدون تسجيل الدخول يستدعي getDoc(blocked_users/{customerPhone}) —
     * يجب السماح بقراءة مستند واحد حسب المعرف وليس قائمة كل المحظورين.
     */
    match /blocked_users/{phone} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /expire-orders/{id} {
      allow read, write: if true;
    }
    match /complete-orders/{id} {
      allow read, write: if true;
    }

    // users/{phone}: الترحيل من التطبيق القديم يستخدم نفس شروط الإنشاء (setDoc بعد createUser على mota7-go)
    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin() || (request.auth != null && userProfileCreateAllowed(userId));
      allow update: if isAdmin() || (request.auth != null && ownsUserProfile(userId) && isUserActive());
      allow delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;

      allow create: if isAdmin() || (request.auth != null && isUserActive() && ownsAdOnCreate());

      allow update: if
        isStatsOnlyAdUpdate() ||
        isProviderServiceRatingAdUpdate() ||
        isAdmin() ||
        (request.auth != null && isUserActive() && ownsAdResource());

      allow delete: if isAdmin() || (request.auth != null && isUserActive() && ownsAdResource());
    }

    /**
     * تجميع نقرات اتصال/واتساب يومياً (لوحة الأدمن: daily_stats → ads_logs).
     * يجب السماح بالكتابة من تطبيق العميل بدون تسجيل (مثل تحديث إحصائيات الإعلان عبر isStatsOnlyAdUpdate)
     * وإلا تفشل كل نقرات الاتصال/الواتساب بـ permission-denied.
     */
    match /daily_stats/{date}/ads_logs/{logId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    /**
     * تصنيفات التطبيق (مجموعة Categories):
     * - قراءة عامة: تطبيق العميل (docData / استعلام orderBy) بدون تسجيل إن لزم.
     * - كتابة كاملة للأدمن: setDoc(merge)، updateDoc، حذف المستند — لوحة «تعديل قوائم التطبيق».
     * ملاحظة: لا توجد حقول فرعية تحت المستند في التصميم الحالي؛ الحقل items مصفوفة داخل المستند.
     */
    match /Categories/{docId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * باقات الاشتراك (وغيرها تحت نفس المجموعة): subscriptions/page — content_html، current_status، إلخ.
     * صريح هنا حتى لا يعتمد العرض على المسار العام فقط (getDoc + أي list لاحق).
     */
    match /subscriptions/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * إعدادات التطبيق العامة (مثل app_config للتحديث الإلزامي — doc(..., 'settings', 'app_config')).
     */
    match /settings/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** الشروط والأحكام: TermsAndConditions/current */
    match /TermsAndConditions/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** بانرات الواجهة */
    match /banners/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** رابط دعوة مجموعة «مُتاح» على واتساب — القراءة للتطبيق بدون إدخال القواعد العامة */
    match /wtsapp_group/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * مجموعة shopping:
     * - مستند ثابت delivery_charges يحوي in / out لمبالغ التوصيل؛ يُنشأ تلقائياً من التطبيق/اللوحة إن لم يكن موجوداً.
     * - مستندات الطلبات ستُضاف لاحقاً بمعرّفات تُولَّد آلياً (حين تُفعَّل القواعد المناسبة لإنشاء الطلب من العميل).
     */
    match /shopping/{docId} {
      /** عموماً: قائمة مجموعة الطلبات للإدارة فقط */
      allow list: if isAdmin();

      /** مستند الأسعار وسندات الطلب عبر المعرف المباشر (يتطلب المعرف الذي يمسكه التطبيق) */
      allow get: if docId == 'delivery_charges'
        || isAdmin()
        || (docId != 'delivery_charges');

      /** أول تهيئة لمستند الأسعار… */
      allow create: if docId == 'delivery_charges'
        && !exists(/databases/$(database)/documents/shopping/delivery_charges)
        && request.resource.data.keys().hasOnly(['in', 'out', 'docType'])
        && request.resource.data.docType == 'delivery_config'
        && request.resource.data.in is string
        && request.resource.data.out is string
        && request.resource.data.in.size() <= 32
        && request.resource.data.out.size() <= 32;

      /**
       * إنشاء طلب شراء من التطبيق:
       */
      allow create: if docId != 'delivery_charges'
        && request.resource.data.buyerName is string
        && request.resource.data.buyerName.size() > 0
        && request.resource.data.buyerPhone is string
        && request.resource.data.buyerPhone.size() >= 10
        && request.resource.data.buyerCity is string
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.grandTotal is number;

      /** عميل الطلب بينما الحالة لا تزال معلقة؛ الأدمن يعدّل دائماً */
      allow update: if isAdmin()
        || (
          docId != 'delivery_charges'
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
        );
      /** عميل أو أدمن: حذف عند الغاء قبل التوصيل أو الرفض (لا حذف عند active لتفادي فقد الشحنة القيد المعالجة) */
      allow delete: if docId != 'delivery_charges'
        && (
          isAdmin()
          || resource.data.status == 'reject'
          || resource.data.status == 'pending'
        );
    }

    /**
     * تناغم FCM خارج الدوال — علامات بمعرّفات آمنة (حساب خدمة فقط عبر firebase-admin، يتجاوز القواعد).
     * لا قراءة/كتابة من العميل.
     */
    match /spark_processed_events/{id} {
      allow read, write: if false;
    }

    /**
     * طابور إعلانات حُفظ بعد نجاح setDoc/updateDoc — المعالجة عبر مشغّل Spark خارجي؛ الحذف بـ Admin.
     */
    match /spark_fcm_jobs/{jobId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['kind', 'ad_id', 'requestedAt'])
        && request.resource.data.kind == 'ad_saved'
        && request.resource.data.ad_id is string
        && request.resource.data.ad_id.size() >= 5
        && request.resource.data.requestedAt is timestamp
        && exists(/databases/$(database)/documents/ads/$(request.resource.data.ad_id))
        && (
          get(/databases/$(database)/documents/ads/$(request.resource.data.ad_id)).data.userId == request.auth.uid
          || (
            userDocIdFromAuth() != '' &&
            get(/databases/$(database)/documents/ads/$(request.resource.data.ad_id)).data.owner_phone == userDocIdFromAuth()
          )
        );
      allow update, delete: if false;
    }

    /**
     * باقي المسارات: قراءة عامة، كتابة للأدمن.
     * مجموعة shopping: لا تُنشَر قراءة طلبات المستخدمين عامة — فقط مستند delivery_charges (والأدمن).
     */
    match /{path=**} {
      allow read: if !(path.matches('shopping/{sid}'))
        || sid == 'delivery_charges'
        || isAdmin();
      allow write: if isAdmin();
    }
  }
}