<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Android 12+ (API 31+):
      استخدم Theme.SplashScreen بشكل صريح مع أيقونة شفافة لمنع ظهور ic_launcher في المنتصف.
      وخلفية splash_launch (لون موحّد) قبل انتقال التطبيق للثيم الأساسي.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>

        <!-- طبقة Splash API -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground">@color/ic_launcher_background</item>

        <!-- خلفية نافذة الإقلاع (full screen) -->
        <item name="android:windowBackground">@drawable/splash_launch</item>

        <!-- ملء الشاشة/النوتش -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
