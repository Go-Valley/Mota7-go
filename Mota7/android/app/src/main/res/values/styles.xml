<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!--
      إقلاع بدون Theme.SplashScreen: خلفية النافذة = splash.png بملء الشاشة.
      يعتمد setTheme() في MainActivity قبل super.onCreate للانتقال إلى NoActionBar.
      إضافة Capacitor قد تفشل installSplashScreen فتستخدم مسار ImageView بملء الشاشة — يعزز ظهور الصورة.
    -->
    <!--
      SplashScreen على Android 12+:
      نحتاج Theme.SplashScreen كي لا يحدث fallback (أيقونة التطبيق بدل صورة splash) على بعض الأجهزة/launchers.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@drawable/splash_launch</item>
        <!-- Branding image يظهر أثناء Splash على Android 12+. -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/splash</item>
        <!-- خلفية أيقونة/رسمة الإقلاع (نخليها شفافة عشان الصورة الأساسية هي الأوضح). -->
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- Animated icon: نستخدم أيقونة اللانشر الموجودة لتجنب fallback. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- خلفية Splash API. -->
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
