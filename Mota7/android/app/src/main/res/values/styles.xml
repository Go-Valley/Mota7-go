<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!--
      Android 12+ (Theme.SplashScreen): طبقة النظام تعرض لوناً + أيقونة مركزية + (اختياري) branding أسفل.
      إزالة BrandingImage كانت تضغط splash.png في شريط سفلي غير منسق.
      أيقونة شفافة بدل ic_launcher_foreground حتى لا يظهر شكل زر/«إيقاف» في المنتصف.
      windowBackground = splash_launch (bitmap fill) يظهر مع الثيم ويُفضّل لملء الشاشة قبل رسم الويب.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:windowBackground">@drawable/splash_launch</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- لون خلفية طبقة Splash API (يُنصح أن يطابق حواف تصميم splash.png) -->
        <item name="android:windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
